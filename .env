# ============================================
# Instagram Metadata Scraper - Variables de Entorno
# ============================================

# Usuario de Instagram (requerido)
# El usuario de la cuenta desde la cual se traerán las cookies
INSTAGRAM_USERNAME=jbalvin
# ============================================
# COOKIES DE SESIÓN (REQUERIDAS)
# ============================================
# Cómo obtener las cookies:
# 1. Abre Instagram en tu navegador y inicia sesión
# 2. Abre DevTools (F12)
# 3. Ve a Application → Cookies → www.instagram.com
# 4. Busca y copia los valores de:
#    - sessionid
#    - csrftoken
#    - ds_user_id

INSTAGRAM_SESSIONID=tu_sessionid_aqui
INSTAGRAM_CSRFTOKEN=tu_csrftoken_aqui
INSTAGRAM_DS_USER_ID=tu_ds_user_id_aqui